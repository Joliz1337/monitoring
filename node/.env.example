# ==========================================
# Server Monitoring Agent Configuration
# mTLS: сертификаты распаковываются из NODE_SECRET в deploy.sh
# ==========================================

# API Settings
API_HOST=127.0.0.1
API_PORT=7500

# mTLS certificates (nginx → panel via ssl_verify_client on)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
CA_CERT_PATH=/etc/nginx/ssl/ca.pem
DOMAIN=monitoring.example.com

# HAProxy (native systemd service on host)
HAPROXY_CONFIG_PATH=/etc/haproxy/haproxy.cfg
HAPROXY_CERTS_DIR=/etc/letsencrypt/live

# Node Identity
NODE_NAME=node-01

# Security (anti-brute-force, rate limiting)
SECURITY_MAX_FAILED_ATTEMPTS=10
SECURITY_BAN_DURATION=3600
SECURITY_RATE_LIMIT_REQUESTS=100
SECURITY_RATE_LIMIT_WINDOW=60

# Traffic Tracking (ports managed via API/panel)
TRAFFIC_DB_PATH=/var/lib/monitoring/traffic.db
TRAFFIC_COLLECT_INTERVAL=60
TRAFFIC_RETENTION_DAYS=90
